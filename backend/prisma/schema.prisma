generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum UserRole {
  ADMIN
  USER
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  DELAYED
  COMPLETED
  TERMINATED
}

enum BranchType {
  SOFTWARE
  HARDWARE
}

enum FeatureStatus {
  NOT_STARTED
  IN_PROGRESS
  DELAYED
  COMPLETED
  TERMINATED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DELAYED
  COMPLETED
  TERMINATED
}

enum EntityType {
  FEATURE
  TASK
  PROJECT
}

// ============== MODELS ==============

model User {
  id        String   @id @default(uuid())
  username  String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdProjects  Project[]  @relation("ProjectCreator")
  managedProjects Project[]  @relation("ProjectManager")
  createdFeatures Feature[]  @relation("FeatureCreator")
  createdTasks    Task[]     @relation("TaskCreator")
  uploadedFiles   File[]    @relation("FileUploader")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  client      String        @default("内部")
  managerId   String?
  vendorId    String?
  startDate   DateTime
  dueDate     DateTime
  finishDate  DateTime?
  status      ProjectStatus @default(NOT_STARTED)
  summary     String?
  remark      String?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  createdBy   User      @relation("ProjectCreator", fields: [createdById], references: [id])
  manager     User?     @relation("ProjectManager", fields: [managerId], references: [id])
  vendor      Vendor?   @relation(fields: [vendorId], references: [id])
  features    Feature[]
  tasks       Task[]
}

model Feature {
  id            String        @id @default(uuid())
  projectId     String
  branchType    BranchType
  name          String
  purpose       String?
  managerId     String?
  buildDate     DateTime?
  plannedStart  DateTime
  plannedEnd    DateTime
  actualEnd     DateTime?
  status        FeatureStatus @default(NOT_STARTED)
  summary       String?
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User        @relation("FeatureCreator", fields: [createdById], references: [id])
  manager       User?       @relation("FeatureManager", fields: [managerId], references: [id])
  tasks         Task[]
  // Note: files are linked via File.entityType='FEATURE' + File.entityId=feature.id
}

model Task {
  id            String      @id @default(uuid())
  featureId     String
  projectId     String
  workContent   String
  targetDate    DateTime
  managerId     String?
  progress      Int         @default(0)
  vendorId      String?
  status        TaskStatus  @default(NOT_STARTED)
  remark        String?
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  feature       Feature     @relation(fields: [featureId], references: [id], onDelete: Cascade)
  project       Project     @relation(fields: [projectId], references: [id])
  vendor        Vendor?     @relation(fields: [vendorId], references: [id])
  createdBy     User       @relation("TaskCreator", fields: [createdById], references: [id])
  manager       User?      @relation("TaskManager", fields: [managerId], references: [id])
  // Note: files are linked via File.entityType='TASK' + File.entityId=task.id
}

model Vendor {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  contactPhone String?
  projectPerson String?
  projectPhone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  tasks         Task[]
  projects      Project[]
}

model File {
  id          String     @id @default(uuid())
  entityType  EntityType
  entityId    String
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  uploaderId  String
  createdAt   DateTime   @default(now())

  // Relations
  uploader    User       @relation("FileUploader", fields: [uploaderId], references: [id])

  // Index for fast lookups by entity
  @@index([entityType, entityId])
}
